+// ====== NNUE Evaluation (akimbo architecture, MIT license) ======
+// Network: 768*4 king-bucketed features → 1024 hidden (SCReLU) → 1 output
+const NNUE_HIDDEN: usize = 1024;
+const NNUE_SCALE: i32 = 400;
+const NNUE_QA: i32 = 255;
+const NNUE_QAB: i32 = NNUE_QA * 64;
+
+#[derive(Clone, Copy)]
+#[repr(C, align(64))]
+struct NnueAcc { vals: [i16; NNUE_HIDDEN] }
+
+#[repr(C)]
+struct NnueNet {
+    feature_weights: [NnueAcc; 768 * 4],
+    feature_bias:    NnueAcc,
+    output_weights:  [NnueAcc; 2],
+    output_bias:     i16,
+}
+
+const _NET_SIZE_CHECK: () = assert!(std::mem::size_of::<NnueNet>() == 6_297_664);
+
+static NNUE: NnueNet = unsafe {
+    std::mem::transmute(*include_bytes!("../resources/net.bin"))
+};
+
+#[rustfmt::skip]
+const NNUE_BUCKET_MAP: [usize; 64] = [
+    0, 0, 1, 1, 5, 5, 4, 4,
+    2, 2, 2, 2, 6, 6, 6, 6,
+    3, 3, 3, 3, 7, 7, 7, 7,
+    3, 3, 3, 3, 7, 7, 7, 7,
+    3, 3, 3, 3, 7, 7, 7, 7,
+    3, 3, 3, 3, 7, 7, 7, 7,
+    3, 3, 3, 3, 7, 7, 7, 7,
+    3, 3, 3, 3, 7, 7, 7, 7,
+];
+
+fn nnue_eval(board: &Board) -> i32 {
+    let stm = board.side_to_move();
+    let wksq = match king_square(board, Color::White) { Some(s) => s.to_index(), None => return 0 };
+    let bksq = match king_square(board, Color::Black) { Some(s) => s.to_index(), None => return 0 };
+
+    // Horizontal flip if king is on right half (so king is always treated as left-half)
+    let w_hflip: usize = if wksq % 8 > 3 { 7 } else { 0 };
+    let b_hflip: usize = if bksq % 8 > 3 { 7 } else { 0 };
+    let wflip = w_hflip;
+    let bflip = b_hflip ^ 56; // also vertical flip for black perspective
+
+    let w_bucket = NNUE_BUCKET_MAP[wksq ^ w_hflip];
+    let b_bucket = NNUE_BUCKET_MAP[(bksq ^ b_hflip) ^ 56];
+
+    let mut white_acc = NNUE.feature_bias.vals;
+    let mut black_acc = NNUE.feature_bias.vals;
+
+    for &color in &[Color::White, Color::Black] {
+        let side = if color == Color::White { 0usize } else { 1 };
+        for &pc in &[Piece::Pawn, Piece::Knight, Piece::Bishop, Piece::Rook, Piece::Queen, Piece::King] {
+            let pc_idx = pc.to_index();
+            // White perspective: own=0, opp=384
+            let w_base = 768 * w_bucket + side * 384 + 64 * pc_idx;
+            // Black perspective: own=0, opp=384 (so black's pieces = side 1 → offset 0)
+            let b_base = 768 * b_bucket + (1 - side) * 384 + 64 * pc_idx;
+            for sq in piece_bb(board, color, pc) {
+                let sq = sq.to_index();
+                let wi = w_base + (sq ^ wflip);
+                let bi = b_base + (sq ^ bflip);
+                let ww = &NNUE.feature_weights[wi].vals;
+                let bw = &NNUE.feature_weights[bi].vals;
+                for i in 0..NNUE_HIDDEN {
+                    white_acc[i] += ww[i];
+                    black_acc[i] += bw[i];
+                }
+            }
+        }
+    }
+
+    let (boys, opps) = if stm == Color::White { (&white_acc, &black_acc) } else { (&black_acc, &white_acc) };
+    let bw = &NNUE.output_weights[0].vals;
+    let ow = &NNUE.output_weights[1].vals;
+    let mut sum = 0i64;
+    for i in 0..NNUE_HIDDEN {
+        let b = boys[i].clamp(0, NNUE_QA as i16) as i64;
+        let o = opps[i].clamp(0, NNUE_QA as i16) as i64;
+        sum += b * b * bw[i] as i64 + o * o * ow[i] as i64;
+    }
+    ((sum / NNUE_QA as i64 + NNUE.output_bias as i64) * NNUE_SCALE as i64 / NNUE_QAB as i64) as i32
+}
